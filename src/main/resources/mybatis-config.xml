<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <!-- MyBatis 全局配置：开启下划线转驼峰，并注册实体别名。 -->
    <settings>
        <setting name="mapUnderscoreToCamelCase" value="true"/>
    </settings>
    <typeAliases>
        <typeAlias alias="User" type="com.ouyeni.ylggxt.entity.User"/>
        <typeAlias alias="Info" type="com.ouyeni.ylggxt.entity.Info"/>
        <typeAlias alias="Registration" type="com.ouyeni.ylggxt.entity.Registration"/>
    </typeAliases>
</configuration>
